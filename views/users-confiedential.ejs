<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Registered Users</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    body { background-color: #f7f9fc; }
    .container { margin-top: 50px; }
    .table-container {
        background: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0px 4px 15px rgba(0,0,0,0.1);
    }
    h2 { margin-bottom: 20px; }
    @media(max-width:768px){
        .table-responsive { font-size: 14px; }
    }
</style>
</head>
<body>
<div class="container">
    <div class="table-container">
        <h2 class="text-center">Registered Users</h2>
        <div class="text-end mb-3">
            <button class="btn btn-warning" onclick="openBroadcastModal()">📢 Broadcast Message</button>
            <button class="btn btn-secondary" onclick="viewMessages()">📩 View All Messages</button>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Signup Date</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(users.length === 0) { %>
                        <tr>
                            <td colspan="7" class="text-center">No registered users</td>
                        </tr>
                    <% } else { %>
                        <% users.forEach((user, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td>
                                    <img src="<%= user.profilePic || 'https://i.pravatar.cc/40?img=3' %>" 
                                        alt="Profile" 
                                        style="width:40px; height:40px; border-radius:50%; object-fit:cover; margin-right:10px;">
                                    <%= user.username %>
                                </td>
                                <td><%= user.email %></td>
                                <td><%= user.phone %></td>
                                <td><%= new Date(user.createdAt).toLocaleString() %></td>
                                <td>
                                    <% if(user.isActive){ %>
                                        <span class="badge bg-success" id="status-<%= user._id %>">Active</span>
                                        <div class="mt-2">
                                            <select class="form-select form-select-sm" onchange="updateStageKYC('<%= user._id %>', this.value)">
                                                <option value="">Select Stage KYC</option>
                                                <option value="Pending" <%= user.stageKyc === 'Pending' ? 'selected' : '' %>>Pending</option>
                                                <option value="Under Review" <%= user.stageKyc === 'Under Review' ? 'selected' : '' %>>Under Review</option>
                                                <option value="Verified" <%= user.stageKyc === 'Verified' ? 'selected' : '' %>>Verified</option>
                                                <option value="Rejected" <%= user.stageKyc === 'Rejected' ? 'selected' : '' %>>Rejected</option>
                                            </select>
                                        </div>
                                    <% } else { %>
                                        <span class="badge bg-danger" id="status-<%= user._id %>">Inactive</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if(user.isActive){ %>
                                        <button class="btn btn-sm btn-danger" onclick="toggleStatus('<%= user._id %>', false)">Deactivate</button>
                                    <% } else { %>
                                        <button class="btn btn-sm btn-success" onclick="toggleStatus('<%= user._id %>', true)">Activate</button>
                                    <% } %>
                                    <button class="btn btn-sm btn-primary mt-1" onclick="openMessageModal('<%= user._id %>')">Send Msg</button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Message Modal -->
<div class="modal fade" id="messageModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content p-3">
      <h5>Send Message</h5>
      <input type="hidden" id="msgUserId">
      <input type="text" id="msgTitle" class="form-control mb-2" placeholder="Title">
      <textarea id="msgBody" class="form-control mb-2" placeholder="Message"></textarea>
      <label>Schedule (Optional)</label>
      <input type="datetime-local" id="scheduleTime" class="form-control mb-2">
      <button class="btn btn-primary" onclick="sendMessage()">Send</button>
      <button class="btn btn-secondary mt-2" data-bs-dismiss="modal">Cancel</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
let messageModal = new bootstrap.Modal(document.getElementById('messageModal'));

// Toggle user active/inactive
async function toggleStatus(userId, newStatus){
    if(!confirm("Are you sure?")) return;
    const res = await fetch(`/admin/toggle-status/${userId}`, {
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body: JSON.stringify({ status: newStatus })
    });
    const data = await res.json();
    if(data.isActive !== undefined){
        const badge = document.getElementById("status-"+userId);
        const button = badge.parentElement.nextElementSibling.querySelector("button");
        if(data.isActive){
            badge.className = "badge bg-success"; badge.innerText = "Active";
            button.className = "btn btn-sm btn-danger"; button.innerText = "Deactivate";
            button.onclick = () => toggleStatus(userId,false);
        } else {
            badge.className = "badge bg-danger"; badge.innerText = "Inactive";
            button.className = "btn btn-sm btn-success"; button.innerText = "Activate";
            button.onclick = () => toggleStatus(userId,true);
        }
    }
}

// Messaging
function openMessageModal(userId){ document.getElementById("msgUserId").value = userId; messageModal.show(); }
function openBroadcastModal(){ document.getElementById("msgUserId").value = ""; messageModal.show(); }
async function sendMessage(){
    const userId = document.getElementById("msgUserId").value;
    const title = document.getElementById("msgTitle").value.trim();
    const message = document.getElementById("msgBody").value.trim();
    const scheduleTime = document.getElementById("scheduleTime").value;
    if(!title || !message){ alert("Title and message cannot be empty"); return; }
    const type = userId ? "single" : "broadcast";
    try{
        const res = await fetch("/admin/send-message", {
            method:"POST", headers:{"Content-Type":"application/json"},
            body: JSON.stringify({ type, userId, title, message, scheduleTime })
        });
        const data = await res.json();
        if(data.success){ alert("Message sent successfully!"); messageModal.hide();
            document.getElementById("msgTitle").value=""; document.getElementById("msgBody").value=""; document.getElementById("scheduleTime").value="";
        } else { alert("Error: "+(data.message || "Unknown error")); }
    } catch(err){ console.error(err); alert("Fetch error: "+err.message); }
}

function viewMessages(){ window.location.href="/admin/messages"; }

// Stage KYC update
async function updateStageKYC(userId, stage){
    if(!stage) return;
    try{
        const res = await fetch(`/admin/update-stage-kyc/${userId}`,{
            method:'POST',
            headers:{"Content-Type":"application/json"},
            body: JSON.stringify({ stageKyc: stage })
        });
        const data = await res.json();
        if(data.success){ alert(`Stage KYC updated to "${stage}"`); }
        else { alert(data.message || "Failed to update Stage KYC"); }
    } catch(err){ console.error(err); alert("Error updating Stage KYC"); }
}
</script>
</body>
</html>